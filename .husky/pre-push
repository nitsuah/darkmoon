#!/usr/bin/env sh
set -e

echo "Running pre-push validation (same as CI)..."

if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    echo "Running tests in Docker..."
    docker compose -f config/docker-compose.yml --project-name darkmoon --profile test run --rm test
    echo "All pre-push checks passed!"
else
    echo "WARNING: Docker not found. Run manually: docker compose -f config/docker-compose.yml --project-name darkmoon --profile test run --rm test"
    exit 1
fi
