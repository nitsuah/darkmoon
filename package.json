{
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "node scripts/develop.js",
    "start": "node server/index.js",
    "format": "prettier --write \"src/*.{js,jsx,json,md,ts,tsx,css}\"",
    "format:check": "prettier --check \"src/*.{js,jsx,json,md,ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --config ./config/eslint.config.js --max-warnings=0 --cache",
    "lint:all": "eslint . --config ./config/eslint.config.js --max-warnings=0 --cache",
    "lint:fix": "eslint src --config ./config/eslint.config.js --max-warnings=0 --fix",
    "lint:docker": "docker compose -f config/docker-compose.yml run --rm app npx lint-staged --config ./config/lint-staged.config.json",
    "precommit": "lint-staged --config ./config/lint-staged.config.json",
    "ci": "npm run typecheck && npm run lint && npm run test:ci && npm run build",
    "test": "vitest --config ./config/vitest.config.ts --configLoader runner",
    "test:ci": "vitest --config ./config/vitest.config.ts --configLoader runner",
    "test:run": "vitest run --config ./config/vitest.config.ts --configLoader runner",
    "prepare": "husky"
  },
  "overrides": {
    "three": "^0.180.0",
    "flatted": "^3.4.2",
    "socket.io-parser": "^4.2.6",
    "ajv": "^6.14.0"
  },
  "dependencies": {
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "socket.io": "^4.8.3",
    "three": "^0.180.0",
    "express-rate-limit": "^8.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "baseline-browser-mapping": "^2.10.34",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "socket.io-client": "^4.8.3",
    "vite": "^8.0.16",
    "vite-plugin-bundle-analyzer": "^0.0.1",
    "vitest": "^4.1.8",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.0"
  }
}
